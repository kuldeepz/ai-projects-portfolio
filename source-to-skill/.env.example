# Copy this file to .env and fill in your values. NEVER commit .env.

# Azure OpenAI — from the Azure portal (Keys and Endpoint blade)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The *deployment* name you created in Azure (often equals the model name).
# Must be a model that supports Structured Outputs (gpt-4.1 / gpt-4o families).
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# API version (default supports Structured Outputs / parse()). Override if needed.
# AZURE_OPENAI_API_VERSION=2024-10-21

# ── Budget (app-side soft cap) ──────────────────────────────────────────────
# The script stops making calls once estimated spend reaches BUDGET_INR.
# Pricing below is GPT-4.1 Global Standard list price (USD/1M tokens); the ₹
# figure = USD cost x USD_TO_INR. Adjust USD_TO_INR to the current FX rate, and
# the USD prices if your Azure contract differs. This only tracks THIS script's
# usage; set an Azure Cost Management budget for the authoritative hard cap.
BUDGET_INR=8000
USD_TO_INR=88
# USD_PER_1M_INPUT=2.0
# USD_PER_1M_CACHED_INPUT=0.50
# USD_PER_1M_OUTPUT=8.0
