# ============================================================
#  Job Search Agent — Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ── EMAIL NOTIFICATIONS ─────────────────────────────────────
# Gmail recommended. For other providers, change SMTP_HOST/PORT in config.py.
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail"
#   4. Paste the 16-character password below (spaces are stripped automatically)

SMTP_USER=you@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Who receives the job digest emails (can be same as SMTP_USER)
NOTIFY_EMAIL=you@gmail.com

# ── AI SCORING (optional but recommended) ───────────────────
# Scores each job against your resume so only relevant roles are emailed.
# Without credentials, ALL matching jobs are sent unscored.
#
# Option A — Standard OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Option B — Azure OpenAI (comment out Option A and fill these instead)
# AZURE_OPENAI_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── RESUME ──────────────────────────────────────────────────
# Path to your resume file. Supports .md (recommended) or .docx
# Relative path is resolved from the project directory.
# Example: resume.md   OR   C:/Users/you/Documents/my_resume.docx
RESUME_PATH=resume.md

# ── SEARCH PREFERENCES ──────────────────────────────────────
# Comma-separated list of job title keywords to search for.
# Case-insensitive. A job matches if its title contains ANY of these.
SEARCH_KEYWORDS=engineering manager,AI lead,ML manager,tech lead,head of engineering,AI manager,machine learning lead

# Minimum AI relevance score (0-100) to include a job in the email.
# Set to 0 to disable filtering and send all matches.
MIN_SCORE=40

# Maximum job age in days (older jobs are ignored)
MAX_JOB_AGE_DAYS=30

# ── TARGET LOCATIONS ────────────────────────────────────────
# Format: "Country: city1, city2; Country2: city3, city4"
# These control which jobs are kept after location filtering.
# For worldwide/remote-only searches, set: LOCATIONS=remote
LOCATIONS=Germany: berlin, munich, frankfurt; Netherlands: amsterdam, rotterdam, utrecht
